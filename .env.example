# ClipFactory secrets template. Copy to .env (GPU worker) and wrangler secret put (Workers).
# Do NOT commit real values. Store production copies in a 1Password vault.

# --- Twitch ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_OAUTH_TOKEN=        # Jordy, clips:edit
TWITCH_BROADCASTER_ID=
TWITCH_BROADCASTER_LOGIN=               # lowercase channel name, e.g. "jordy"
TWITCH_BOT_OAUTH_TOKEN=                 # chat:read (oauth:xxxx form for IRC)
TWITCH_BOT_NICK=                        # bot account login

# --- LLMs / media ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVER_CHAT_ID=
TELEGRAM_JORDY_CHAT_ID=

# --- n8n / Metricool ---
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_CALLBACK_SECRET=                    # shared secret for the callback we expose

# --- Cloudflare R2 (S3-compatible, used by GPU worker) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=clip-bucket
R2_ENDPOINT=                            # https://<account>.r2.cloudflarestorage.com

# --- Cloudflare Queues pull (GPU worker) ---
CLOUDFLARE_ACCOUNT_ID=
CF_QUEUES_PULL_TOKEN=
CF_CLIP_EDIT_QUEUE_ID=

# --- Dashboard / misc ---
DASHBOARD_JWT_SECRET=
DASHBOARD_ADMIN_SECRET=                 # (optional) dedicated secret for dashboard token issuance; falls back to GPU_INTERNAL_SECRET
RESEND_API_KEY=
ALERT_EMAIL_TO=

# --- GPU worker runtime ---
GPU_WORKER_ID=gpu-01
GPU_HEARTBEAT_URL=                      # approval-worker /api/gpu/heartbeat endpoint
GPU_D1_API_URL=                         # approval-worker /api/internal/clips endpoint
GPU_INTERNAL_SECRET=                    # shared secret between GPU worker and API
